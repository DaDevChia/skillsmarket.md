APIFY_TOKEN=
APIFY_USER_ID=
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-5.4-mini
SKILLSMARKET_PUBLIC_HOSTNAME=skillsmarket.onrender.com
SKILLSMARKET_FRONTEND_URL=http://127.0.0.1:5173
SKILLSMARKET_BACKEND_URL=http://127.0.0.1:8000
USE_DIRECT_MYCAREERSFUTURE=true
USE_APIFY_SECONDARY=true
# Resume analysis calls the LLM automatically when OPENROUTER_API_KEY is set, and
# fails closed to the deterministic engine otherwise. Set to false to force the
# deterministic-only path even when a key is present.
SKILLSMARKET_ENABLE_LLM_RESUME=true
